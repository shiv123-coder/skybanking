<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd" version="4.0" metadata-complete="false">
    <absolute-ordering />
    <display-name>Sky Banking System</display-name>
    <description>Complete MNC-ready banking system with admin panel</description>

    <!-- ================= ERROR PAGES ================= -->
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>

    <!-- ================= SESSION CONFIG ================= -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>true</secure>
        </cookie-config>
    </session-config>

    <!-- Security is enforced by AdminAuthFilter; no container constraint to avoid 403s without a realm. -->

    <!-- ================= WELCOME FILES ================= -->
    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- ================= MIME TYPES ================= -->
    <mime-mapping>
        <extension>pdf</extension>
        <mime-type>application/pdf</mime-type>
    </mime-mapping>
    <mime-mapping>
        <extension>json</extension>
        <mime-type>application/json</mime-type>
    </mime-mapping>

    <!-- Database configuration loaded via environment variables -->

    <!-- Servlets and filters are registered via annotations (@WebServlet/@WebFilter). -->

    <!-- Removed broken JSP includes (header.jspf/footer.jspf not present) to prevent 500 errors. -->

    <!-- ================= SECURITY ROLE ================= -->
    <security-role>
        <role-name>admin</role-name>
    </security-role>

    <servlet>
        <servlet-name>ping</servlet-name>
        <servlet-class>com.skybanking.web.PingServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ping</servlet-name>
        <url-pattern>/ping</url-pattern>
    </servlet-mapping>

</web-app>
